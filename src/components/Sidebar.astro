---
import Logo from './Logo.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';

// Home / Clubbing / Contact are live routes; the rest are inert placeholders
// (muted, non-navigating) — exactly as in the design.
const navItems: { label: string; href: string | null }[] = [
	{ label: 'Acasă', href: '/' },
	{ label: 'Nunți', href: null },
	{ label: 'Club', href: '/clubbing' },
	{ label: 'Botez', href: null },
	{ label: 'Artă', href: null },
	{ label: 'Despre', href: null },
	{ label: 'Contact', href: '/contact' },
];

const isActive = (href: string | null) =>
	href === '/'
		? path === '/'
		: !!href && (path === href || path.startsWith(`${href}/`));
---

<aside class="pj-sidebar" id="pj-sidebar" data-open="false">
	<div>
		<a href="/" aria-label="PJ Arts — acasă" style="display:inline-block;">
			<Logo width={56} glitch />
		</a>

		<div style="margin-top:26px;">
			<div class="pj-sidebar__name">PJ Arts</div>
			<div class="pj-sidebar__tag">Omul tău din spatele obiectivului</div>
		</div>

		<nav class="pj-nav">
			{
				navItems.map((item) =>
					item.href ? (
						<a
							href={item.href}
							class:list={[isActive(item.href) && 'is-active']}
							aria-current={isActive(item.href) ? 'page' : undefined}
						>
							{item.label}
						</a>
					) : (
						<a class="is-inert" aria-disabled="true">
							{item.label}
						</a>
					),
				)
			}
		</nav>

		<!-- mobile-only theme control (lives in the drawer) -->
		<div class="pj-drawer-ctl">
			<button type="button" class="pj-btn" data-theme-toggle>
				<span data-theme-label>Light</span> mode
			</button>
		</div>
	</div>

	<div class="pj-sidebar__foot">
		<div style="margin-bottom:14px;">
			Toate aceste imagini și proiecții<br />ale mele au aparținut anului 2025
		</div>
		<div class="pj-social">
			<a
				href="https://www.facebook.com/pauljph"
				target="_blank"
				rel="noopener"
				aria-label="Facebook"
			>
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
					><path
						d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"
					></path></svg
				>
			</a>
			<a
				href="https://www.instagram.com/paulj_arts"
				target="_blank"
				rel="noopener"
				aria-label="Instagram"
			>
				<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
					><path
						d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.38C1.35 2.68.94 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-10.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"
					></path></svg
				>
			</a>
		</div>
	</div>
</aside>
